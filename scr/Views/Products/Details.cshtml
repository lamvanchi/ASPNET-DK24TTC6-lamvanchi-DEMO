@model AppleStoreWeb.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var images = System.Text.Json.JsonSerializer.Deserialize<string[]>(Model.Images) ?? new string[0];
    var storageOptions = System.Text.Json.JsonSerializer.Deserialize<string[]>(Model.StorageOptions) ?? new string[0];
    var colors = System.Text.Json.JsonSerializer.Deserialize<string[]>(Model.Colors) ?? new string[0];
}

<div class="container mt-4">

    <div class="row">

        <div class="col-md-6">

            @if (images.Any())
            {
                    <div id="productCarousel" class="carousel slide">
                        <div class="carousel-inner">
                        @for (int i = 0; i < images.Length; i++)
                        {
                                    <div class="carousel-item @(i == 0 ? "active" : "")">
                                        <img src="@images[i]" class="d-block w-100" style="height:350px; object-fit:contain;">
                                    </div>
                        }
                        </div>

                    @if (images.Length > 1)
                    {
                                <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev"></button>
                                <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next"></button>
                    }
                    </div>

                @if (images.Length > 1)
                {
                            <div class="d-flex mt-2 gap-2">
                        @for (int i = 0; i < Math.Min(images.Length, 4); i++)
                        {
                                        <img src="@images[i]" class="img-thumbnail" style="height:60px; object-fit:contain; cursor:pointer;" onclick="changeMainImage(@i)">
                        }
                            </div>
                }
            }
            else
            {
                    <img src="/images/placeholder.jpg" class="img-fluid">
            }

        </div>

        <div class="col-md-6">

            <h5 class="mb-2">@Model.Name</h5>

            <small class="text-muted">@Model.Brand</small>

            <div class="mt-2 mb-3">
                <span class="fw-bold text-danger">@Model.Price.ToString("N0") ₫</span>
            </div>

            @if (Model.InStock)
            {
                    <div class="small text-success mb-3">Còn hàng</div>
            }
            else
            {
                    <div class="small text-muted mb-3">Hết hàng</div>
            }

            <div class="mb-3 small">
                @Model.Description
            </div>

            <form id="addToCartForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="productId" value="@Model.Id">

                @if (storageOptions.Any())
                {
                        <div class="mb-3">
                            <div class="small mb-1">Dung lượng</div>
                        @foreach (var s in storageOptions)
                        {
                                    <input type="radio" class="btn-check" name="storageOption" id="s-@s" value="@s">
                                    <label class="btn btn-outline-dark btn-sm me-1 mb-1" for="s-@s">@s</label>
                        }
                        </div>
                }

                @if (colors.Any())
                {
                        <div class="mb-3">
                            <div class="small mb-1">Màu</div>
                        @foreach (var c in colors)
                        {
                                    <input type="radio" class="btn-check" name="color" id="c-@c" value="@c">
                                    <label class="btn btn-outline-dark btn-sm me-1 mb-1" for="c-@c">@c</label>
                        }
                        </div>
                }

                <div class="mb-3">
                    <div class="small mb-1">Số lượng</div>
                    <div class="input-group input-group-sm" style="width:120px;">
                        <button type="button" class="btn btn-outline-dark" onclick="changeQuantity(-1)">-</button>
                        <input type="number" class="form-control text-center" id="quantity" value="1" min="1">
                        <button type="button" class="btn btn-outline-dark" onclick="changeQuantity(1)">+</button>
                    </div>
                </div>

                @if (Model.InStock)
                {
                        <button type="submit" class="btn btn-dark me-2">Thêm vào giỏ</button>
                }
                else
                {
                        <button type="button" class="btn btn-secondary" disabled>Hết hàng</button>
                }

            </form>

        </div>

    </div>

    <div class="mt-4">
        <h6>Mô tả</h6>
        <div class="small text-muted">
            @Model.Description
        </div>
    </div>

</div>

<script>
function changeMainImage(i) {
    var c = document.getElementById('productCarousel');
    var ins = bootstrap.Carousel.getInstance(c) || new bootstrap.Carousel(c);
    ins.to(i);
}

function changeQuantity(d) {
    var input = document.getElementById('quantity');
    var v = parseInt(input.value) || 1;
    v = Math.max(1, v + d);
    input.value = v;
}

document.getElementById('addToCartForm').addEventListener('submit', function(e) {
    e.preventDefault();

    var id = document.getElementById('productId').value;
    var qty = document.getElementById('quantity').value;
    var storage = document.querySelector('input[name="storageOption"]:checked')?.value;
    var color = document.querySelector('input[name="color"]:checked')?.value;

    if (!storage) {
        alert('Chọn dung lượng');
        return;
    }

    if (!color) {
        alert('Chọn màu');
        return;
    }

    var formData = new FormData();
    formData.append('productId', id);
    formData.append('quantity', qty);
    formData.append('storageOption', storage);
    formData.append('color', color);
    formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

    fetch('/Cart/AddToCart', {
        method: 'POST',
        body: formData
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) {
            alert('Đã thêm vào giỏ');
        }
    });
});
</script>

<style>
.img-thumbnail:hover {
    border-color: black;
}
</style>