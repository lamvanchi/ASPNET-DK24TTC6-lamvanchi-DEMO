@model IEnumerable<AppleStoreWeb.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var filter = ViewBag.Filter as AppleStoreWeb.Models.FilterState;
    var categories = ViewBag.Categories as List<string>;
    var brands = ViewBag.Brands as List<string>;
    var productTypes = ViewBag.ProductTypes as List<string>;
    var storageOptions = ViewBag.StorageOptions as List<string>;
    var colors = ViewBag.Colors as List<string>;
}

<div class="container mt-4">
    <div class="row">

        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">

                    <form asp-action="Index" method="get">

                        <div class="mb-3">
                            <input type="text" class="form-control" name="filter.Search" value="@filter?.Search" placeholder="Tìm sản phẩm...">
                        </div>

                        <div class="mb-3">
                            <select class="form-select" name="filter.Brand">
                                <option value="">Thương hiệu</option>
                                @if (brands != null)
                                {
                                    foreach (var b in brands)
                                    {
                                                <option value="@b" selected="@(filter?.Brand == b)">@b</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <select class="form-select" name="filter.ProductType">
                                <option value="">Loại sản phẩm</option>
                                @if (productTypes != null)
                                {
                                    foreach (var t in productTypes)
                                    {
                                                <option value="@t" selected="@(filter?.ProductType == t)">@t</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <input type="number" class="form-control" name="filter.MinPrice" value="@filter?.MinPrice" placeholder="Giá từ">
                            </div>
                            <div class="col-6">
                                <input type="number" class="form-control" name="filter.MaxPrice" value="@filter?.MaxPrice" placeholder="Đến">
                            </div>
                        </div>

                        <div class="mb-3">
                            <select class="form-select" name="filter.StorageOption">
                                <option value="">Dung lượng</option>
                                @if (storageOptions != null)
                                {
                                    foreach (var s in storageOptions.OrderBy(x => x))
                                    {
                                                <option value="@s" selected="@(filter?.StorageOption == s)">@s</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <select class="form-select" name="filter.Color">
                                <option value="">Màu sắc</option>
                                @if (colors != null)
                                {
                                    foreach (var c in colors)
                                    {
                                                <option value="@c" selected="@(filter?.Color == c)">@c</option>
                                    }
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 mb-2">Lọc</button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-dark w-100">Xóa</a>

                    </form>

                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5>Sản phẩm</h5>
                <small class="text-muted">@Model.Count() sản phẩm</small>
            </div>

            @if (Model.Any())
            {
                    <div class="row">

                    @foreach (var product in Model)
                    {
                                <div class="col-lg-4 col-md-6 mb-4">

                                    <div class="card h-100 shadow-sm">

                                @{
                                    var images = System.Text.Json.JsonSerializer.Deserialize<string[]>(product.Images);
                                    var img = images?.FirstOrDefault() ?? "/images/placeholder.jpg";
                                }

                                        <img src="@img" class="card-img-top" style="height:200px; object-fit:contain;">

                                        <div class="card-body d-flex flex-column">

                                            <h6 class="mb-1">@product.Name</h6>
                                            <small class="text-muted">@product.Brand</small>

                                            <div class="mt-2 mb-2 small text-muted">
                                        @product.Description
                                            </div>

                                            <div class="mt-auto">

                                        @if (product.OriginalPrice.HasValue && product.OriginalPrice > product.Price)
                                        {
                                                        <div class="small text-muted text-decoration-line-through">
                                                @product.OriginalPrice.Value.ToString("N0") ₫
                                                        </div>
                                        }

                                                <div class="fw-bold text-danger mb-2">
                                            @product.Price.ToString("N0") ₫
                                                </div>

                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <small class="text-muted">
                                                        ⭐ @product.Rating (@product.Reviews)
                                                    </small>

                                            @if (product.InStock)
                                            {
                                                            <span class="badge bg-success">Còn</span>
                                            }
                                            else
                                            {
                                                            <span class="badge bg-secondary">Hết</span>
                                            }
                                                </div>

                                                <div>
                                                    <a class="btn btn-dark btn-sm me-1" asp-action="Details" asp-route-id="@product.Id">
                                                        Xem
                                                    </a>

                                            @if (product.InStock)
                                            {
                                                            <button class="btn btn-outline-dark btn-sm add-to-cart-btn"
                                                                    data-product-id="@product.Id"
                                                                    data-product-name="@product.Name">
                                                                Thêm
                                                            </button>
                                            }
                                                </div>

                                            </div>

                                        </div>
                                    </div>

                                </div>
                    }

                    </div>
            }
            else
            {
                    <div class="text-center py-5">
                        <h6 class="text-muted">Không có sản phẩm</h6>
                    </div>
            }

        </div>

    </div>
</div>

<style>
.card {
    transition: 0.2s;
}
.card:hover {
    transform: translateY(-4px);
}
</style>