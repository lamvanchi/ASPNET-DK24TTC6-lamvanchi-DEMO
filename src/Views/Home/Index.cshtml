@model IEnumerable<AppleStoreWeb.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- SLIDER -->
<div id="homeSlider" class="carousel slide" data-bs-ride="carousel">

    <div class="carousel-inner">

        <!-- SLIDE 1 -->
        <div class="carousel-item active">
            <div class="slider-item text-center">

                <div class="top-text">
                    <h1>iPhone 17e</h1>
                    <p>Đủ tính năng. Đầy giá trị.</p>
                </div>

                <div class="middle-img">
                    <img src="/images/iphone-banner.png">
                </div>

                <div class="bottom-btn">
                    <a class="btn-buy">Mua ngay</a>
                </div>

            </div>
        </div>

        <!-- SLIDE 2 -->
        <div class="carousel-item">
            <div class="slider-item text-center">

                <div class="top-text">
                    <h1>iPad Pro M3</h1>
                    <p>Hiệu năng cực mạnh</p>
                </div>

                <div class="middle-img">
                    <img src="/images/ipad.png">
                </div>

                <div class="bottom-btn">
                    <a class="btn-buy">Mua ngay</a>
                </div>

            </div>
        </div>

        <!-- SLIDE 3 -->
        <div class="carousel-item">
            <div class="slider-item text-center">

                <div class="top-text">
                    <h1>MacBook Air</h1>
                    <p>Mỏng nhẹ - Đỉnh cao</p>
                </div>

                <div class="middle-img">
                    <img src="/images/mac.png">
                </div>

                <div class="bottom-btn">
                    <a class="btn-buy">Mua ngay</a>
                </div>

            </div>
        </div>

    </div>

</div>

<div class="container">

    <!-- MENU -->
    <div class="row text-center my-4">
        <div class="col"><a class="menu-link">iPhone</a></div>
        <div class="col"><a class="menu-link">iPad</a></div>
        <div class="col"><a class="menu-link">Mac</a></div>
        <div class="col"><a class="menu-link">Watch</a></div>
        <div class="col"><a class="menu-link">Phụ kiện</a></div>
    </div>

    <!-- PRODUCT -->
    <div class="mb-5">
        <div class="section-header">
            <h4>iPhone</h4>
            <a asp-controller="Products" asp-action="Index">Xem tất cả</a>
        </div>

        <div class="row">
            @foreach (var product in Model.Take(8))
            {
                var images = System.Text.Json.JsonSerializer.Deserialize<string[]>(product.Images);
                var firstImage = images?.FirstOrDefault() ?? "";

                    <div class="col-lg-3 col-md-4 col-6 mb-4">
                        <div class="product-card">

                            <img src="@firstImage" />

                            <h6>@product.Name</h6>

                        @if (product.OriginalPrice.HasValue && product.OriginalPrice > product.Price)
                        {
                                    <div class="old-price">
                                @product.OriginalPrice.Value.ToString("N0") ₫
                                    </div>
                        }

                            <div class="new-price">
                            @product.Price.ToString("N0") ₫
                            </div>

                            <a class="btn-detail"
                               asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@product.Id">
                                Xem chi tiết
                            </a>

                        </div>
                    </div>
            }
        </div>
    </div>

</div>

<style>

body {
    background: #f5f5f7;
}

/* ===== SLIDER ===== */
.slider-item {
    height: 550px;
    background: #fff;

    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;

    padding: 40px 20px;
}

/* TEXT */
.top-text h1 {
    font-size: 44px;
    font-weight: 700;
}
.top-text p {
    font-size: 18px;
    color: #6e6e73;
}

/* IMAGE CENTER */
.middle-img {
    flex-grow: 1;
    display: flex;
    justify-content: center;
    align-items: center;
}

.middle-img img {
    max-width: 100%;
    max-height: 260px;
    object-fit: contain;
}

/* BUTTON */
.bottom-btn {
    margin-bottom: 10px;
}

.btn-buy {
    background: #0071e3;
    color: white;
    padding: 10px 25px;
    border-radius: 25px;
    text-decoration: none;
}
.btn-buy:hover {
    background: #005bb5;
}

/* MENU */
.menu-link {
    text-decoration: none;
    color: black;
    font-weight: 500;
}
.menu-link:hover {
    color: #0071e3;
}

/* SECTION */
.section-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
}

/* PRODUCT */
.product-card {
    background: #fff;
    border-radius: 15px;
    padding: 15px;
    text-align: center;
    transition: 0.3s;
}
.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}
.product-card img {
    height: 180px;
    object-fit: contain;
}
.old-price {
    text-decoration: line-through;
    color: #999;
    font-size: 13px;
}
.new-price {
    color: #d70018;
    font-weight: 600;
}
.btn-detail {
    display: inline-block;
    border: 1px solid #ccc;
    padding: 5px 12px;
    border-radius: 20px;
    text-decoration: none;
    color: black;
    font-size: 13px;
}
.btn-detail:hover {
    background: black;
    color: white;
}

</style>

<script>
    var myCarousel = document.querySelector('#homeSlider');
    new bootstrap.Carousel(myCarousel, {
        interval: 3000,
        ride: 'carousel',
        pause: false
    });
</script>